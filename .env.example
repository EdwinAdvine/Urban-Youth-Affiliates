# ─── Application ───────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
APP_NAME="Y&U Affiliates"
APP_VERSION=1.0.0

# ─── Frontend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_PORT=3000

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=yua_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=yua_db
DATABASE_URL=postgresql+asyncpg://yua_user:change-me-strong-password@localhost:5432/yua_db
DATABASE_READ_URL=        # Optional read replica

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=           # Optional

# ─── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-must-be-at-least-32-characters-long-keep-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Paystack ──────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ─── Email ─────────────────────────────────────────────────────────────────
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yuaffiliates.co.ke
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yuaffiliates.co.ke
SMTP_FROM_NAME="Y&U Affiliates"

# ─── Celery ────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Platform Settings ─────────────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=0.10          # 10% default
MIN_PAYOUT_THRESHOLD=500              # KES 500 minimum
COOKIE_DAYS=30                        # Referral cookie duration
AFFILIATE_REQUIRE_APPROVAL=true       # Require admin approval for new affiliates

# ─── Store Webhook ─────────────────────────────────────────────────────────
STORE_API_KEY=change-me-store-api-key # Shared key for store conversion webhooks

# ─── Observability (Optional) ──────────────────────────────────────────────
SENTRY_DSN=
ENABLE_TRACING=false
ENABLE_METRICS=true
